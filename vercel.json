{
  "rewrites": [
    {
      "source": "/((?!static|favicon.ico|manifest.json|logo192.png|logo512.png).*)",
      "destination": "/index.html"
    },
    {
      "source": "/api/:path*",
      "destination": "http://167.71.52.80:8080/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}